{
  "registryName": "Enterprise-Architecture-Patterns",
  "version": "2026.03.01",
  "deployment_hierarchies": [
    {
      "id": "on-prem-ocp",
      "name": "On-Prem OpenShift Deployment",
      "valid_layer_chain": [
        "Region",
        "Datacenter",
        "Cluster",
        "Namespace"
      ]
    },
    {
      "id": "cots-vm",
      "name": "COTS VMs Deployment",
      "valid_layer_chain": [
        "Region",
        "Datacenter",
        "vSphere Cluster",
        "Virtual Machine"
      ]
    },
    {
      "id": "azure-serverless",
      "name": "Azure Serverless Deployment",
      "valid_layer_chain": [
        "Azure Region",
        "Resource Group",
        "App Service Plan",
        "Function"
      ]
    }
  ],
  "patterns": [
    {
      "id": "internal-api-ocp",
      "name": "Internal API on OpenShift",
      "version": "2.1.0",
      "c4Level": "Container",
      "description": "Multi-region API deployment with GSLB and API Gateway ingress.",
      "parameters": {
        "topology": {
          "type": "string",
          "options": [
            "active-active",
            "active-passive"
          ],
          "default": "active-passive"
        }
      },
      "rules": [
        {
          "id": "db-compatibility-rule",
          "description": "Enforce DB selection based on topology",
          "condition": "topology == 'active-active'",
          "allowed_values": {
            "database_type": [
              "yugabyte",
              "mongodb"
            ]
          },
          "else_allowed_values": {
            "database_type": [
              "mongodb",
              "sql-server",
              "oracle",
              "postgresql"
            ]
          }
        },
        {
          "id": "multi-region-spanning-rule",
          "description": "Active-Active API topology must be deployed across at least 2 distinct Regions and 2 distinct Datacenters per Region.",
          "condition": "topology == 'active-active'",
          "structural_assertions": [
            "count(distinct(deployment.regions)) >= 2",
            "count(deployment.datacenters_per_region) >= 2",
            "assert(traffic.routing == 'weighted_round_robin')"
          ]
        }
      ],
      "infrastructure_requirements": {
        "host_capability": "openshift-cluster-v4",
        "replication_factor": 4,
        "regions": 2,
        "allowed_hierarchies": [
          "on-prem-ocp"
        ]
      },
      "macro_expansion": {
        "nodes": [
          {
            "id_suffix": "cluster",
            "type": "hostNode",
            "pattern_ref": "openshift-cluster-v4@4.12.0",
            "label": "Standard OpenShift Cluster Instance",
            "layer": "Cluster",
            "c4Level": "DeploymentNode"
          },
          {
            "id_suffix": "lb",
            "type": "infrastructureNode",
            "pattern_ref": "local-load-balancer@2.0.0",
            "label": "Local Load Balancer Instance",
            "c4Level": "InfrastructureNode",
            "properties": {
              "provider": "avi"
            }
          },
          {
            "id_suffix": "gw",
            "type": "infrastructureNode",
            "pattern_ref": "api-gateway@2.0.0",
            "label": "API Gateway Instance",
            "c4Level": "InfrastructureNode",
            "properties": {
              "provider": "apigee"
            }
          }
        ],
        "edges": [
          {
            "source_suffix": "lb",
            "target_suffix": "cluster"
          },
          {
            "source_suffix": "gw",
            "target_suffix": "lb"
          }
        ],
        "workload_target_suffix": "cluster"
      },
      "crossplane_mapping": {
        "kind": "XInternalAPI",
        "apiVersion": "arch.acme.com/v1alpha1"
      }
    },
    {
      "id": "batch-workload-ocp",
      "name": "Autosys Batch on OpenShift",
      "version": "1.4.0",
      "c4Level": "Container",
      "description": "Batch job triggered by Autosys via Kubernetes Plugin.",
      "parameters": {
        "scheduler": {
          "type": "string",
          "const": "autosys"
        },
        "backup_region_enabled": {
          "type": "boolean",
          "default": true
        }
      },
      "infrastructure_requirements": {
        "host_capability": "openshift-cluster-v4",
        "required_plugins": [
          "autosys-k8s-agent"
        ],
        "allowed_hierarchies": [
          "on-prem-ocp"
        ]
      },
      "macro_expansion": {
        "nodes": [
          {
            "id_suffix": "cluster",
            "type": "hostNode",
            "pattern_ref": "openshift-cluster-v4@4.12.0",
            "label": "Standard OpenShift Cluster Instance",
            "layer": "Cluster",
            "c4Level": "DeploymentNode"
          }
        ],
        "edges": [],
        "workload_target_suffix": "cluster"
      },
      "crossplane_mapping": {
        "kind": "XBatchJob",
        "apiVersion": "arch.acme.com/v1alpha1"
      }
    },
    {
      "id": "region",
      "name": "Cloud Region",
      "version": "1.0.0",
      "c4Level": "DeploymentNode",
      "type": "Region",
      "layer": "Region",
      "default_width": 1200,
      "default_height": 1000,
      "parameters": {
        "region_id": {
          "type": "string",
          "default": "us-east-1"
        }
      }
    },
    {
      "id": "datacenter",
      "name": "Datacenter",
      "version": "1.0.0",
      "c4Level": "DeploymentNode",
      "type": "Datacenter",
      "layer": "Datacenter",
      "default_width": 1000,
      "default_height": 800,
      "rules": [
        {
          "id": "dc-placement-rule",
          "description": "Datacenter must be placed within a Region boundary.",
          "structural_assertions": [
            "assert(parent.layer == 'Region')"
          ]
        }
      ],
      "parameters": {
        "dc_id": {
          "type": "string",
          "default": "DC1"
        }
      }
    },
    {
      "id": "api-gateway",
      "name": "API Gateway",
      "version": "2.0.0",
      "c4Level": "InfrastructureNode",
      "type": "Host",
      "capabilities": [
        "api-gateway-ingress"
      ],
      "rules": [
        {
          "id": "gateway-placement-rule",
          "description": "API Gateway must be deployed within a Datacenter boundary.",
          "structural_assertions": [
            "assert(parent.type == 'Datacenter')"
          ]
        }
      ],
      "parameters": {
        "provider": {
          "type": "string",
          "options": [
            "apigee",
            "datapower"
          ],
          "default": "apigee"
        }
      }
    },
    {
      "id": "local-load-balancer",
      "name": "Local Load Balancer",
      "version": "2.0.0",
      "c4Level": "InfrastructureNode",
      "type": "Host",
      "capabilities": [
        "haproxy-ingress",
        "avi"
      ],
      "rules": [
        {
          "id": "lb-placement-rule",
          "description": "Load Balancer must be deployed within a Datacenter boundary.",
          "structural_assertions": [
            "assert(parent.type == 'Datacenter')"
          ]
        }
      ],
      "parameters": {
        "provider": {
          "type": "string",
          "const": "avi"
        }
      }
    },
    {
      "id": "openshift-cluster-v4",
      "name": "Standard OpenShift Cluster",
      "version": "4.12.0",
      "c4Level": "DeploymentNode",
      "type": "Cluster",
      "layer": "Cluster",
      "default_width": 600,
      "default_height": 500,
      "rules": [
        {
          "id": "cluster-placement-rule",
          "description": "Cluster must be placed within a Datacenter boundary.",
          "structural_assertions": [
            "assert(parent.layer == 'Datacenter')"
          ]
        }
      ],
      "capabilities": [
        "openshift-cluster-v4",
        "k8s-api-access",
        "haproxy-ingress"
      ]
    }
  ]
}